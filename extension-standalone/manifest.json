{
  "manifest_version": 3,
  "name": "CookieGuard AI",
  "version": "3.0",
  "description": "AI-powered cookie security scanner. No backend required — runs entirely in your browser.",

  "permissions": [
    "cookies",
    "activeTab",
    "tabs",
    "storage"
  ],

  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    },
    "default_title": "CookieGuard AI - Click to scan cookies"
  },

  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },

  "host_permissions": ["<all_urls>"],

  "web_accessible_resources": [
    {
      "resources": ["model/*", "lib/*"],
      "matches": ["<all_urls>"]
    }
  ],

  "content_security_policy": {
    "extension_pages": "script-src 'self' 'wasm-unsafe-eval'; object-src 'self'"
  }
}
